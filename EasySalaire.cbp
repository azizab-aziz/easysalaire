<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="EasySalaire" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/EasySalaire" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
					<Add directory="C:/EasySalaire/lib/raylib" />
					<Add directory=" C:/EasySalaire/lib/raygui" />
				</Compiler>
				<Linker>
					<Add option="lraylib" />
					<Add option="lopengl32" />
					<Add option="lgdi32" />
					<Add option="lwinmm" />
					<Add directory="C:/EasySalaire/lib/raylib" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/EasySalaire" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
					<Add directory="C:/EasySalaire/lib/raylib" />
					<Add directory=" C:/EasySalaire/lib/raygui" />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add directory="C:/EasySalaire/lib/raylib" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add directory="C:/EasySalaire/lib/raylib" />
			<Add directory="C:/EasySalaire/lib/raygui" />
			<Add directory="lib/raylib" />
			<Add directory="lib/raygui" />
		</Compiler>
		<Linker>
			<Add option="C:\EasySalaire\lib\raylib\libraylib.a" />
			<Add library="opengl32" />
			<Add library="gdi32" />
			<Add library="winmm" />
			<Add directory="C:/EasySalaire/lib/raylib" />
			<Add directory="lib/raylib" />
		</Linker>
		<Unit filename="src/employe.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="src/employe.h" />
		<Unit filename="src/main.c">
			<Option compilerVar="CC" />
		</Unit>
		<Extensions />
	</Project>
</CodeBlocks_project_file>
